rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only logged-in users can access POS state
    match /pos_state/{docId} {
      allow read, write: if request.auth != null;
    }

    // Sales history - unlimited docs, but only for logged-in users
    match /sales/{saleId} {
      allow read, write: if request.auth != null;
    }

    // Optional: app config (for updates etc.), readable but not writable from app
    match /app_config/{configId} {
      allow read: if true;            // anyone can read
      allow write: if false;          // only via Firebase Console / server
    }
  }
}